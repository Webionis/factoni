# =============================================================================
# Factoni — variables PRODUCTION (Vercel → Environment: Production)
# Copier vers .env.production en local pour npm run predeploy:check
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=https://fduqyjadzkslykszpxgj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=https://factoni.fr

# Serveur uniquement — jamais NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=

TZ=Europe/Paris

# --- Stripe Connect (paiements clients → compte artisan) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Dashboard Stripe → Webhooks → https://factoni.fr/api/stripe/webhook
# Événements : checkout.session.completed

# --- Stripe Billing (abonnement Factoni Starter / Pro) ---
# Auto-activé si price IDs + STRIPE_SECRET_KEY présents (STRIPE_BILLING_ENABLED optionnel)
STRIPE_BILLING_ENABLED=true
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_BILLING_WEBHOOK_SECRET=whsec_...
# Dashboard Stripe → Webhooks → https://factoni.fr/api/webhooks/stripe
# Événements : checkout.session.completed, customer.subscription.*, invoice.paid, invoice.payment_failed

# --- Emails transactionnels ---
RESEND_API_KEY=re_...
EMAIL_FROM=Factoni <contact@factoni.fr>

# --- Cron relances (Vercel Cron 8h UTC) ---
CRON_SECRET=

# --- Lancement commercial (optionnel — auto si prod + billing configuré) ---
# FACTONI_PRODUCTION_LAUNCH=true
# BILLING_LIMITS_ENFORCED=true

# --- Migrations prod (npm run db:migrate:prod) ---
# Option A — mot de passe seul (connexion directe auto) :
SUPABASE_DB_PASSWORD=
# Option B — URI complète depuis Supabase → Connect → URI :
# SUPABASE_DB_URL=postgresql://postgres:...@db.fduqyjadzkslykszpxgj.supabase.co:5432/postgres

# --- Facturation électronique (optionnel) ---
# EINVOICING_ENABLED=false

# --- Monitoring (optionnel) ---
# NEXT_PUBLIC_SENTRY_DSN=
