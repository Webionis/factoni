# =============================================================================
# Factoni — variables d'environnement
# Copier vers .env.local (local) ou les renseigner sur Vercel (Production)
# =============================================================================

# --- Obligatoires (3) — préfixe NEXT_PUBLIC_ = exposées au navigateur (OK avec RLS) ---

# Supabase → Project Settings → API (région EU recommandée)
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre-cle-anon-publique

# URL canonique de l'app (metadata, SEO, liens)
# Local : http://localhost:3000
# Production : https://factoni.fr (redirection secondaire : https://factoni.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Optionnel ---

# Cron relances factures (Vercel Cron — Authorization: Bearer <secret>)
# CRON_SECRET=your-random-secret

# Resend — emails transactionnels (relances factures, notifications artisan)
# Les envois initiaux facture/devis passent par mailto (messagerie de l'artisan)
# Serveur uniquement — ne jamais exposer au client
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM="Factoni <contact@factoni.fr>"

# Monitoring (stub prêt — installer @sentry/nextjs pour activer)
# NEXT_PUBLIC_SENTRY_DSN=

# --- Stripe Connect Express (paiements factures → compte artisan) ---

# Dashboard Stripe → Developers → API keys (mode test)
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Généré par : npm run stripe:listen (copier whsec_ puis redémarrer npm run dev)
# STRIPE_WEBHOOK_SECRET=whsec_...

# Migration locale : npm run stripe:migrate
# Dashboard Supabase → Project Settings → Database → Database password
# SUPABASE_DB_PASSWORD=

# Abonnement Factoni (billing bêta — route séparée /api/webhooks/stripe)
# STRIPE_PRICE_STARTER_MONTHLY=
# STRIPE_PRICE_PRO_MONTHLY=

# --- Facturation électronique (Plateforme Agréée intégrée) ---

# Active la transmission automatique à l'envoi d'une facture B2B.
# EINVOICING_ENABLED=true
# Clé API partenaire Iopole (ou autre PA) — serveur uniquement
# EINVOICING_API_KEY=
# EINVOICING_API_BASE_URL=https://api.iopole.com
# Simulation locale sans clé API (développement)
# EINVOICING_USE_DEV_PROVIDER=true

# --- NE PAS utiliser sur Vercel / côté client ---

# Bypass RLS — lien client + signature électronique (Storage)
# Requis pour « Copier le lien client » et /api/public/d/[token]/sign
# Project Settings → API → service_role (secret)
# Enregistrer le fichier puis redémarrer npm run dev
# SUPABASE_SERVICE_ROLE_KEY=
